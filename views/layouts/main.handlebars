<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} — W&M Delivery</title>
    {{#each styles}}
        <link rel="stylesheet" href="{{this}}">
    {{/each}}
</head>
<body>

<nav class="navbar">
    <a href="/" class="navbar-logo">
        <img src="/assets/logo.jpeg" alt="W&M Delivery" style="height:48px; width:auto; object-fit:contain;" />
    </a>
    <ul class="navbar-links">
        <li><a href="/">Accueil</a></li>
        <li><a href="/#services">Services</a></li>
        <li><a href="/#comment">Comment ça marche</a></li>
    </ul>
    <div class="navbar-actions">
        {{#if user}}
            <a href="/dashboard" class="btn btn-outline">Mon espace</a>
            {{#if isAdmin}}
                <a href="/admin" class="btn btn-primary">Administration</a>
            {{/if}}
        {{else}}
            <a href="/connexion" class="btn btn-outline">Connexion</a>
            <a href="/inscription" class="btn btn-primary">S'inscrire</a>
        {{/if}}
    </div>
</nav>

{{{body}}}

<footer>
    <a href="/">
        <img src="/assets/logo.jpeg" alt="W&M Delivery" style="height:44px; width:auto; object-fit:contain;" />
    </a>
    <p>© 2026 W&M Delivery — Tous droits réservés</p>
</footer>

{{#each scripts}}
    <script src="{{this}}"></script>
{{/each}}

</body>
</html>