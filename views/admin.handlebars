<div style="max-width:1200px; margin:2rem auto; padding:0 2rem;">

    <!-- HEADER -->
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
        <div>
            <p style="color:var(--gray-light); font-size:0.9rem; margin-bottom:0.3rem;">W&M Delivery</p>
            <h1 style="font-size:1.8rem; font-weight:800;">⚙️ Administration</h1>
        </div>
        <button onclick="seDeconnecter()" class="btn btn-outline btn-sm">Déconnexion</button>
    </div>

    <!-- STATS RAPIDES -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:1rem; margin-bottom:2.5rem;">
        <div class="card" style="text-align:center; padding:1.2rem;">
            <div style="font-size:1.8rem; font-weight:800; color:var(--green);">{{candidatures.length}}</div>
            <div style="color:var(--gray-light); font-size:0.82rem;">Candidatures</div>
        </div>
        <div class="card" style="text-align:center; padding:1.2rem;">
            <div style="font-size:1.8rem; font-weight:800; color:var(--green);">{{employes.length}}</div>
            <div style="color:var(--gray-light); font-size:0.82rem;">Employés</div>
        </div>
        <div class="card" style="text-align:center; padding:1.2rem;">
            <div style="font-size:1.8rem; font-weight:800; color:var(--green);">{{colis.length}}</div>
            <div style="color:var(--gray-light); font-size:0.82rem;">Colis</div>
        </div>
        <div class="card" style="text-align:center; padding:1.2rem;">
            <div style="font-size:1.8rem; font-weight:800; color:var(--green);">{{routes.length}}</div>
            <div style="color:var(--gray-light); font-size:0.82rem;">Routes</div>
        </div>
        <div class="card" style="text-align:center; padding:1.2rem;">
            <div style="font-size:1.8rem; font-weight:800; color:var(--green);">{{paiements.length}}</div>
            <div style="color:var(--gray-light); font-size:0.82rem;">Paiements</div>
        </div>
    </div>

    <!-- TABS -->
    <div style="display:flex; gap:0.5rem; margin-bottom:2rem; flex-wrap:wrap;">
        <button class="tab-btn active" onclick="showTab('candidatures', this)">📄 Candidatures</button>
        <button class="tab-btn" onclick="showTab('employes', this)">👷 Employés</button>
        <button class="tab-btn" onclick="showTab('colis', this)">📦 Colis</button>
        <button class="tab-btn" onclick="showTab('routes', this)">🗺️ Routes</button>
        <button class="tab-btn" onclick="showTab('paiements', this)">💰 Paiements</button>
    </div>

    <!-- CANDIDATURES -->
    <div id="tab-candidatures" class="tab-pane active">
        <div class="card" style="padding:1.5rem;">
            <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1.2rem;">📄 Candidatures reçues</h2>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border);">
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Nom</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Email</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">CV</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Statut</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each candidatures}}
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:0.8rem 1rem; font-weight:600;">{{this.nom}}</td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">{{this.email}}</td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">{{this.cv}}</td>
                        <td style="padding:0.8rem 1rem;">
                            <span class="statut-badge statut-{{this.statut}}">{{this.statut}}</span>
                        </td>
                        <td style="padding:0.8rem 1rem; display:flex; gap:0.5rem;">
                            <button onclick="updateCandidature({{this.id}}, 'accepte')" class="btn btn-primary btn-sm">✅ Accepter</button>
                            <button onclick="updateCandidature({{this.id}}, 'refuse')" class="btn btn-danger btn-sm">❌ Refuser</button>
                        </td>
                    </tr>
                    {{else}}
                    <tr><td colspan="5" style="padding:2rem; text-align:center; color:var(--gray-light);">Aucune candidature.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- EMPLOYÉS -->
    <div id="tab-employes" class="tab-pane">
        <div class="card" style="padding:1.5rem;">
            <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1.2rem;">👷 Gestion des employés</h2>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border);">
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Nom</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Email</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Statut</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each employes}}
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:0.8rem 1rem; font-weight:600;">{{this.name}}</td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">{{this.email}}</td>
                        <td style="padding:0.8rem 1rem;">
                            {{#if this.actif}}
                                <span class="statut-badge statut-livre">✅ Actif</span>
                            {{else}}
                                <span class="statut-badge statut-retourne">❌ Inactif</span>
                            {{/if}}
                        </td>
                        <td style="padding:0.8rem 1rem;">
                            <button onclick="toggleEmploye({{this.id}}, {{this.actif}})" class="btn btn-outline btn-sm">
                                {{#if this.actif}}Désactiver{{else}}Activer{{/if}}
                            </button>
                        </td>
                    </tr>
                    {{else}}
                    <tr><td colspan="4" style="padding:2rem; text-align:center; color:var(--gray-light);">Aucun employé.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- COLIS -->
    <div id="tab-colis" class="tab-pane">
        <div class="card" style="padding:1.5rem;">
            <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1.2rem;">📦 Gestion des colis</h2>
            <div style="display:flex; gap:0.8rem; margin-bottom:1.5rem; flex-wrap:wrap;">
                <input type="text" id="colis-description" placeholder="Description du colis..." style="flex:1; padding:0.65rem 1rem; border-radius:8px; border:1px solid var(--border); background:var(--dark); color:var(--white); font-size:0.9rem; min-width:200px;">
                <button onclick="addColis()" class="btn btn-primary">+ Ajouter un colis</button>
            </div>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border);">
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">ID</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Description</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Statut</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Livreur</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each colis}}
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">#{{this.id}}</td>
                        <td style="padding:0.8rem 1rem; font-weight:600;">{{this.description}}</td>
                        <td style="padding:0.8rem 1rem;">
                            <span class="statut-badge statut-{{this.statut}}">{{this.statut}}</span>
                        </td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">
                            {{#if this.livreur}}{{this.livreur.name}}{{else}}—{{/if}}
                        </td>
                        <td style="padding:0.8rem 1rem;">
                            <button onclick="deleteColis({{this.id}})" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
                        </td>
                    </tr>
                    {{else}}
                    <tr><td colspan="5" style="padding:2rem; text-align:center; color:var(--gray-light);">Aucun colis.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- ROUTES -->
    <div id="tab-routes" class="tab-pane">
        <div class="card" style="padding:1.5rem;">
            <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1.2rem;">🗺️ Gestion des routes</h2>
            <div style="display:flex; gap:0.8rem; margin-bottom:1.5rem; flex-wrap:wrap;">
                <input type="text" id="route-nom" placeholder="Nom de la route..." style="flex:1; padding:0.65rem 1rem; border-radius:8px; border:1px solid var(--border); background:var(--dark); color:var(--white); font-size:0.9rem; min-width:200px;">
                <button onclick="addRoute()" class="btn btn-primary">+ Ajouter une route</button>
            </div>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border);">
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Nom</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Stops</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Statut</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each routes}}
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:0.8rem 1rem; font-weight:600;">{{this.nom}}</td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">{{this.stops.length}} stop(s)</td>
                        <td style="padding:0.8rem 1rem;">
                            {{#if this.actif}}
                                <span class="statut-badge statut-livre">✅ Active</span>
                            {{else}}
                                <span class="statut-badge statut-retourne">❌ Inactive</span>
                            {{/if}}
                        </td>
                        <td style="padding:0.8rem 1rem;">
                            <button onclick="deleteRoute({{this.id}})" class="btn btn-danger btn-sm">🗑️ Supprimer</button>
                        </td>
                    </tr>
                    {{else}}
                    <tr><td colspan="4" style="padding:2rem; text-align:center; color:var(--gray-light);">Aucune route.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- PAIEMENTS -->
    <div id="tab-paiements" class="tab-pane">
        <div class="card" style="padding:1.5rem;">
            <h2 style="font-size:1.1rem; font-weight:700; margin-bottom:1.2rem;">💰 Gestion des paiements</h2>
            <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid var(--border);">
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Livreur</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Montant</th>
                        <th style="text-align:left; padding:0.7rem 1rem; color:var(--gray-light); font-size:0.8rem; text-transform:uppercase;">Période</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each paiements}}
                    <tr style="border-bottom:1px solid var(--border);">
                        <td style="padding:0.8rem 1rem; font-weight:600;">{{this.livreur.name}}</td>
                        <td style="padding:0.8rem 1rem; color:var(--green); font-weight:700;">{{this.montant}} $</td>
                        <td style="padding:0.8rem 1rem; color:var(--gray-light);">{{this.periode}}</td>
                    </tr>
                    {{else}}
                    <tr><td colspan="3" style="padding:2rem; text-align:center; color:var(--gray-light);">Aucun paiement.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

</div>

<style>
.tab-btn {
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--border);
    background: var(--dark2);
    color: var(--gray-light);
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 600;
    transition: all 0.2s;
}
.tab-btn:hover, .tab-btn.active {
    background: var(--green);
    color: var(--white);
    border-color: var(--green);
}
.tab-pane { display: none; }
.tab-pane.active { display: block; }
.statut-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
}
.statut-en_attente { background:#37415133; color:#9ca3af; border:1px solid #374151; }
.statut-en_cours   { background:#1d4ed833; color:#60a5fa; border:1px solid #2563eb; }
.statut-livre      { background:#14532d33; color:#4ade80; border:1px solid #16a34a; }
.statut-retourne   { background:#7f1d1d33; color:#f87171; border:1px solid #dc2626; }
.statut-accepte    { background:#14532d33; color:#4ade80; border:1px solid #16a34a; }
.statut-refuse     { background:#7f1d1d33; color:#f87171; border:1px solid #dc2626; }
</style>