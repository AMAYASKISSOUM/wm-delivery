<div style="min-height:80vh; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div style="width:100%; max-width:420px;">

        <!-- LOGO -->
        <div style="text-align:center; margin-bottom:2rem;">
            <div style="font-size:2rem; font-weight:800; margin-bottom:0.3rem;">🚚 W&M <span style="color:var(--green);">Delivery</span></div>
            <p style="color:var(--gray-light); font-size:0.9rem;">Créez votre compte livreur</p>
        </div>

        <!-- CARD -->
        <div class="card" style="padding:2rem;">
            <h2 style="font-size:1.3rem; font-weight:700; margin-bottom:1.5rem; text-align:center;">Inscription</h2>

            <div style="display:flex; flex-direction:column; gap:1.2rem;">

                <div>
                    <label style="display:block; font-size:0.85rem; color:var(--gray-light); margin-bottom:0.4rem; font-weight:600;">Nom complet</label>
                    <input
                        type="text"
                        id="name"
                        placeholder="ex: Michel Tremblay"
                        style="width:100%; padding:0.75rem 1rem; border-radius:8px; border:1px solid var(--border); background:var(--dark); color:var(--white); font-size:0.95rem; outline:none; transition:border-color 0.2s;"
                        onfocus="this.style.borderColor='var(--green)'"
                        onblur="this.style.borderColor='var(--border)'"
                    />
                </div>

                <div>
                    <label style="display:block; font-size:0.85rem; color:var(--gray-light); margin-bottom:0.4rem; font-weight:600;">Adresse email</label>
                    <input
                        type="email"
                        id="email"
                        placeholder="ex: michel@email.com"
                        style="width:100%; padding:0.75rem 1rem; border-radius:8px; border:1px solid var(--border); background:var(--dark); color:var(--white); font-size:0.95rem; outline:none; transition:border-color 0.2s;"
                        onfocus="this.style.borderColor='var(--green)'"
                        onblur="this.style.borderColor='var(--border)'"
                    />
                </div>

                <div>
                    <label style="display:block; font-size:0.85rem; color:var(--gray-light); margin-bottom:0.4rem; font-weight:600;">Mot de passe</label>
                    <input
                        type="password"
                        id="password"
                        placeholder="Minimum 6 caractères"
                        style="width:100%; padding:0.75rem 1rem; border-radius:8px; border:1px solid var(--border); background:var(--dark); color:var(--white); font-size:0.95rem; outline:none; transition:border-color 0.2s;"
                        onfocus="this.style.borderColor='var(--green)'"
                        onblur="this.style.borderColor='var(--border)'"
                    />
                </div>

                <div id="message" style="display:none; padding:0.75rem 1rem; border-radius:8px; font-size:0.88rem; text-align:center;"></div>

                <button onclick="sInscrire()" class="btn btn-primary" style="width:100%; justify-content:center; padding:0.85rem; font-size:1rem;">
                    Créer mon compte →
                </button>

            </div>

            <p style="text-align:center; margin-top:1.5rem; font-size:0.88rem; color:var(--gray-light);">
                Déjà un compte ? <a href="/connexion" style="color:var(--green); font-weight:600;">Se connecter</a>
            </p>
        </div>

    </div>
</div>

<script>
async function sInscrire() {
    const name = document.getElementById("name").value.trim();
    const email = document.getElementById("email").value.trim();
    const password = document.getElementById("password").value.trim();
    const msg = document.getElementById("message");

    if (!name || !email || !password) {
        msg.style.display = "block";
        msg.style.background = "#7f1d1d33";
        msg.style.border = "1px solid #dc2626";
        msg.style.color = "#f87171";
        msg.textContent = "Veuillez remplir tous les champs.";
        return;
    }

    const res = await fetch("/api/add-user", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, password })
    });

    if (res.ok) {
        msg.style.display = "block";
        msg.style.background = "#14532d33";
        msg.style.border = "1px solid #16a34a";
        msg.style.color = "#4ade80";
        msg.textContent = "Compte créé avec succès ! Redirection...";
        setTimeout(() => window.location.href = "/connexion", 1500);
    } else {
        const data = await res.json();
        msg.style.display = "block";
        msg.style.background = "#7f1d1d33";
        msg.style.border = "1px solid #dc2626";
        msg.style.color = "#f87171";
        msg.textContent = data.errorMessage || "Erreur lors de l'inscription.";
    }
}
</script>